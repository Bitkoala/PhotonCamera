<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <FrameLayout
        android:id="@+id/gallery_photo_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/gallery_photo_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FF1A1A1A"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/gallery_photo_selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#4DFF6B35"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/gallery_photo_selection_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/gallery_photo_video_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_gallery_badge_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_gallery_play"
                android:tint="#FFFFFFFF" />

            <TextView
                android:id="@+id/gallery_photo_video_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:fontFamily="sans"
                android:includeFontPadding="false"
                android:lineHeight="14sp"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/gallery_photo_motion_icon"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/ic_live_photo"
            android:tint="#FFFFFFFF"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/gallery_photo_burst_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/ic_gallery_burst"
            android:tint="#FFFFFFFF"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/gallery_photo_bottom_badges"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/gallery_photo_raw_badge"
                style="@style/GallerySmallBadge"
                android:text="RAW"
                android:visibility="gone" />

            <TextView
                android:id="@+id/gallery_photo_imported_badge"
                style="@style/GallerySmallBadge"
                android:visibility="gone" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/gallery_photo_related_badge"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_gallery_badge_rect"
            android:padding="2dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/auto_awesome"
                android:tint="#FFFFFFFF" />
        </FrameLayout>
    </FrameLayout>
</merge>
